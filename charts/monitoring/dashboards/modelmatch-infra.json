{
  "annotations": { "list": [] },
  "editable": true,
  "graphTooltip": 1,
  "schemaVersion": 39,
  "tags": ["modelmatch", "infra", "devops"],
  "title": "ModelMatch — Infra/DevOps (P21)",
  "uid": "modelmatch-infra",
  "time": { "from": "now-1h", "to": "now" },
  "refresh": "30s",
  "templating": {
    "list": [
      {
        "name": "datasource",
        "label": "Data source",
        "type": "datasource",
        "query": "prometheus",
        "current": {},
        "hide": 0,
        "refresh": 1,
        "regex": ""
      }
    ]
  },
  "panels": [
    {
      "id": 100,
      "type": "row",
      "title": "Nodes",
      "collapsed": false,
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 0 },
      "panels": []
    },
    {
      "id": 1,
      "type": "stat",
      "title": "Node CPU utilisation (cluster avg)",
      "gridPos": { "h": 4, "w": 12, "x": 0, "y": 1 },
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "fieldConfig": {
        "defaults": {
          "unit": "percent", "decimals": 1, "min": 0, "max": 100,
          "thresholds": { "mode": "absolute", "steps": [
            { "color": "green", "value": null },
            { "color": "yellow", "value": 70 },
            { "color": "red", "value": 90 }
          ] }
        },
        "overrides": []
      },
      "options": { "colorMode": "value", "graphMode": "area", "reduceOptions": { "calcs": ["lastNotNull"] } },
      "targets": [
        { "refId": "A", "datasource": { "type": "prometheus", "uid": "${datasource}" },
          "expr": "100 * (1 - avg(rate(node_cpu_seconds_total{mode=\"idle\"}[5m])))" }
      ]
    },
    {
      "id": 2,
      "type": "stat",
      "title": "Node memory utilisation (cluster avg)",
      "gridPos": { "h": 4, "w": 12, "x": 12, "y": 1 },
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "fieldConfig": {
        "defaults": {
          "unit": "percent", "decimals": 1, "min": 0, "max": 100,
          "thresholds": { "mode": "absolute", "steps": [
            { "color": "green", "value": null },
            { "color": "yellow", "value": 75 },
            { "color": "red", "value": 90 }
          ] }
        },
        "overrides": []
      },
      "options": { "colorMode": "value", "graphMode": "area", "reduceOptions": { "calcs": ["lastNotNull"] } },
      "targets": [
        { "refId": "A", "datasource": { "type": "prometheus", "uid": "${datasource}" },
          "expr": "100 * (1 - sum(node_memory_MemAvailable_bytes) / sum(node_memory_MemTotal_bytes))" }
      ]
    },
    {
      "id": 3,
      "type": "timeseries",
      "title": "Node CPU utilisation by node",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 5 },
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "fieldConfig": { "defaults": { "unit": "percent", "min": 0, "max": 100, "custom": { "drawStyle": "line", "fillOpacity": 10 } }, "overrides": [] },
      "options": { "legend": { "displayMode": "list", "placement": "bottom" }, "tooltip": { "mode": "multi" } },
      "targets": [
        { "refId": "A", "datasource": { "type": "prometheus", "uid": "${datasource}" },
          "expr": "100 * (1 - avg by (instance) (rate(node_cpu_seconds_total{mode=\"idle\"}[5m])))", "legendFormat": "{{instance}}" }
      ]
    },
    {
      "id": 4,
      "type": "timeseries",
      "title": "Node memory utilisation by node",
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 5 },
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "fieldConfig": { "defaults": { "unit": "percent", "min": 0, "max": 100, "custom": { "drawStyle": "line", "fillOpacity": 10 } }, "overrides": [] },
      "options": { "legend": { "displayMode": "list", "placement": "bottom" }, "tooltip": { "mode": "multi" } },
      "targets": [
        { "refId": "A", "datasource": { "type": "prometheus", "uid": "${datasource}" },
          "expr": "100 * (1 - sum by (instance) (node_memory_MemAvailable_bytes) / sum by (instance) (node_memory_MemTotal_bytes))", "legendFormat": "{{instance}}" }
      ]
    },
    {
      "id": 101,
      "type": "row",
      "title": "Pods",
      "collapsed": false,
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 13 },
      "panels": []
    },
    {
      "id": 5,
      "type": "timeseries",
      "title": "Pod CPU usage — top 10 (app/argocd/monitoring/ingress/cnpg)",
      "gridPos": { "h": 9, "w": 12, "x": 0, "y": 14 },
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "fieldConfig": { "defaults": { "unit": "short", "decimals": 3, "custom": { "drawStyle": "line", "fillOpacity": 10 } }, "overrides": [] },
      "options": { "legend": { "displayMode": "table", "placement": "right", "calcs": ["lastNotNull"] }, "tooltip": { "mode": "multi" } },
      "targets": [
        { "refId": "A", "datasource": { "type": "prometheus", "uid": "${datasource}" },
          "expr": "topk(10, sum by (namespace, pod) (rate(container_cpu_usage_seconds_total{container!=\"\",namespace=~\"app|argocd|monitoring|nginx-ingress|cnpg-system\"}[5m])))", "legendFormat": "{{namespace}}/{{pod}}" }
      ]
    },
    {
      "id": 6,
      "type": "timeseries",
      "title": "Pod memory working set — top 10 (app/argocd/monitoring/ingress/cnpg)",
      "gridPos": { "h": 9, "w": 12, "x": 12, "y": 14 },
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "fieldConfig": { "defaults": { "unit": "bytes", "custom": { "drawStyle": "line", "fillOpacity": 10 } }, "overrides": [] },
      "options": { "legend": { "displayMode": "table", "placement": "right", "calcs": ["lastNotNull"] }, "tooltip": { "mode": "multi" } },
      "targets": [
        { "refId": "A", "datasource": { "type": "prometheus", "uid": "${datasource}" },
          "expr": "topk(10, sum by (namespace, pod) (container_memory_working_set_bytes{container!=\"\",namespace=~\"app|argocd|monitoring|nginx-ingress|cnpg-system\"}))", "legendFormat": "{{namespace}}/{{pod}}" }
      ]
    },
    {
      "id": 102,
      "type": "row",
      "title": "Pod restarts",
      "collapsed": false,
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 23 },
      "panels": []
    },
    {
      "id": 7,
      "type": "stat",
      "title": "Container restarts (last 1h, cluster-wide)",
      "gridPos": { "h": 7, "w": 6, "x": 0, "y": 24 },
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "fieldConfig": {
        "defaults": {
          "unit": "short", "decimals": 0,
          "thresholds": { "mode": "absolute", "steps": [
            { "color": "green", "value": null },
            { "color": "yellow", "value": 1 },
            { "color": "red", "value": 5 }
          ] }
        },
        "overrides": []
      },
      "options": { "colorMode": "background", "graphMode": "area", "reduceOptions": { "calcs": ["lastNotNull"] } },
      "targets": [
        { "refId": "A", "datasource": { "type": "prometheus", "uid": "${datasource}" },
          "expr": "sum(increase(kube_pod_container_status_restarts_total[1h]))" }
      ]
    },
    {
      "id": 8,
      "type": "table",
      "title": "Container restart counts by pod (top 15)",
      "gridPos": { "h": 7, "w": 18, "x": 6, "y": 24 },
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "fieldConfig": { "defaults": { "unit": "short", "custom": { "align": "auto" } }, "overrides": [] },
      "options": { "showHeader": true, "sortBy": [ { "displayName": "restarts", "desc": true } ] },
      "targets": [
        { "refId": "A", "datasource": { "type": "prometheus", "uid": "${datasource}" },
          "expr": "topk(15, sum by (namespace, pod) (kube_pod_container_status_restarts_total))", "format": "table", "instant": true }
      ],
      "transformations": [
        { "id": "organize", "options": {
          "excludeByName": { "Time": true, "__name__": true, "job": true, "service": true, "instance": true, "endpoint": true, "container": true, "uid": true },
          "renameByName": { "Value": "restarts", "namespace": "namespace", "pod": "pod" }
        } }
      ]
    },
    {
      "id": 103,
      "type": "row",
      "title": "ArgoCD",
      "collapsed": false,
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 31 },
      "panels": []
    },
    {
      "id": 9,
      "type": "stat",
      "title": "Apps Synced",
      "gridPos": { "h": 4, "w": 6, "x": 0, "y": 32 },
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "fieldConfig": { "defaults": { "unit": "short", "decimals": 0, "thresholds": { "mode": "absolute", "steps": [ { "color": "green", "value": null } ] } }, "overrides": [] },
      "options": { "colorMode": "value", "graphMode": "none", "reduceOptions": { "calcs": ["lastNotNull"] } },
      "targets": [
        { "refId": "A", "datasource": { "type": "prometheus", "uid": "${datasource}" },
          "expr": "count(argocd_app_info{sync_status=\"Synced\"}) or vector(0)" }
      ]
    },
    {
      "id": 10,
      "type": "stat",
      "title": "Apps OutOfSync",
      "gridPos": { "h": 4, "w": 6, "x": 6, "y": 32 },
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "fieldConfig": {
        "defaults": {
          "unit": "short", "decimals": 0,
          "thresholds": { "mode": "absolute", "steps": [
            { "color": "green", "value": null },
            { "color": "red", "value": 1 }
          ] }
        },
        "overrides": []
      },
      "options": { "colorMode": "background", "graphMode": "none", "reduceOptions": { "calcs": ["lastNotNull"] } },
      "targets": [
        { "refId": "A", "datasource": { "type": "prometheus", "uid": "${datasource}" },
          "expr": "count(argocd_app_info{sync_status!=\"Synced\"}) or vector(0)" }
      ]
    },
    {
      "id": 11,
      "type": "stat",
      "title": "Apps Healthy",
      "gridPos": { "h": 4, "w": 6, "x": 12, "y": 32 },
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "fieldConfig": { "defaults": { "unit": "short", "decimals": 0, "thresholds": { "mode": "absolute", "steps": [ { "color": "green", "value": null } ] } }, "overrides": [] },
      "options": { "colorMode": "value", "graphMode": "none", "reduceOptions": { "calcs": ["lastNotNull"] } },
      "targets": [
        { "refId": "A", "datasource": { "type": "prometheus", "uid": "${datasource}" },
          "expr": "count(argocd_app_info{health_status=\"Healthy\"}) or vector(0)" }
      ]
    },
    {
      "id": 12,
      "type": "stat",
      "title": "Apps not Healthy",
      "gridPos": { "h": 4, "w": 6, "x": 18, "y": 32 },
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "fieldConfig": {
        "defaults": {
          "unit": "short", "decimals": 0,
          "thresholds": { "mode": "absolute", "steps": [
            { "color": "green", "value": null },
            { "color": "red", "value": 1 }
          ] }
        },
        "overrides": []
      },
      "options": { "colorMode": "background", "graphMode": "none", "reduceOptions": { "calcs": ["lastNotNull"] } },
      "targets": [
        { "refId": "A", "datasource": { "type": "prometheus", "uid": "${datasource}" },
          "expr": "count(argocd_app_info{health_status!=\"Healthy\"}) or vector(0)" }
      ]
    },
    {
      "id": 13,
      "type": "table",
      "title": "ArgoCD applications — sync & health",
      "gridPos": { "h": 9, "w": 24, "x": 0, "y": 36 },
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "fieldConfig": {
        "defaults": { "custom": { "align": "auto" } },
        "overrides": [
          { "matcher": { "id": "byName", "options": "sync_status" }, "properties": [ { "id": "mappings", "value": [
            { "type": "value", "options": { "Synced": { "color": "green", "index": 0 }, "OutOfSync": { "color": "red", "index": 1 } } }
          ] }, { "id": "custom.cellOptions", "value": { "type": "color-text" } } ] },
          { "matcher": { "id": "byName", "options": "health_status" }, "properties": [ { "id": "mappings", "value": [
            { "type": "value", "options": { "Healthy": { "color": "green", "index": 0 }, "Degraded": { "color": "red", "index": 1 }, "Progressing": { "color": "yellow", "index": 2 }, "Missing": { "color": "red", "index": 3 } } }
          ] }, { "id": "custom.cellOptions", "value": { "type": "color-text" } } ] }
        ]
      },
      "options": { "showHeader": true, "sortBy": [ { "displayName": "name", "desc": false } ] },
      "targets": [
        { "refId": "A", "datasource": { "type": "prometheus", "uid": "${datasource}" },
          "expr": "argocd_app_info", "format": "table", "instant": true }
      ],
      "transformations": [
        { "id": "filterFieldsByName", "options": { "include": { "pattern": "^(name|project|sync_status|health_status|dest_namespace)$" } } },
        { "id": "organize", "options": {
          "indexByName": { "name": 0, "project": 1, "dest_namespace": 2, "sync_status": 3, "health_status": 4 },
          "renameByName": { "dest_namespace": "namespace" }
        } }
      ]
    }
  ]
}
